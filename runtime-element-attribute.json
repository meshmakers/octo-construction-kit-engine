{
  "$id": "https://schemas.meshmakers.cloud/runtime-elements-attribute.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "RtAttribute": {
      "type": "object",
      "title": "RtAttribute",
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9-_.]+/[a-zA-Z0-9-_.]+$"
        },
        "value": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "boolean"
            },
            {
              "type": "number"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            {
              "type": "array",
              "items": {
                "type": "number"
              }
            }

          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "id"
      ]
    }
  }
}