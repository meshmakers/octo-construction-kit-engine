<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net8.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <RootNamespace>Meshmakers.ConstructionKit.Samples.SourceGenerator</RootNamespace>
        <OctoCompilerToolPath>../../bin/$(Configuration)/net7.0/octo-ckc</OctoCompilerToolPath>
        <OctoSkipCkCompile Condition="'$(Configuration)'=='Release'">true</OctoSkipCkCompile>
    </PropertyGroup>
    
    <!-- Import the ConstructionKit.SourceGeneration props and targets only because the package is not used as nuget package -->
    <Import Project="../../src/ConstructionKit.SourceGeneration/build/Meshmakers.Octo.ConstructionKit.SourceGeneration.props"  />
    <Import Project="../../src/ConstructionKit.SourceGeneration/build/Meshmakers.Octo.ConstructionKit.SourceGeneration.targets"  />

    <ItemGroup>
      <ProjectReference Include="..\..\src\ConstructionKit.Contracts\ConstructionKit.Contracts.csproj" />
      <ProjectReference Include="..\..\src\ConstructionKit.SourceGeneration\ConstructionKit.SourceGeneration.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" PrivateAssets="all" />
      <ProjectReference Include="..\..\src\Runtime.Contracts\Runtime.Contracts.csproj" />
    </ItemGroup>
    <ItemGroup>
      <None Remove="ConstructionKit\ck-sample1.yaml" />
      <None Remove="ConstructionKit\ck-sample1.cache.json" />
    </ItemGroup>
    <ItemGroup>
      <AdditionalFiles Include="ConstructionKit\ck-sample1.cache.json" />
      <EmbeddedResource Include="ConstructionKit\ck-sample1.yaml">
        <GenerateCkModelServiceClass>true</GenerateCkModelServiceClass>
      </EmbeddedResource>
    </ItemGroup>
    <ItemGroup>
      <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="8.0.0" />
    </ItemGroup>
</Project>
