{
  "$id": "https://schemas.meshmakers.cloud/construction-kit-compiled.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "$schema":{
      "type": "string",
      "format": "uri"
    },
    "modelId": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9-.]+$"
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-zA-Z0-9-.]+$"
      }
    },
    "attributes": {
      "type": "array",
      "items": {
        "type": "object",
        "$ref": "https://schemas.meshmakers.cloud/construction-kit-elements-attribute.schema.json"
      }
    },
    "types": {
      "type": "array",
      "items": {
        "type": "object",
        "$ref": "https://schemas.meshmakers.cloud/construction-kit-elements-type.schema.json"
      }
    },
    "associationRoles":{
      "type": "array",
      "items": {
        "type": "object",
        "$ref": "https://schemas.meshmakers.cloud/construction-kit-elements-associationRole.schema.json"
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "modelId"
  ]
}