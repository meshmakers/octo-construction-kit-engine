{
  "$id": "https://schemas.meshmakers.cloud/construction-kit-elements-associationRole.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "CkAssociationRole": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9-_.]+$"
        },
        "inboundName": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_.]+$"
        },
        "outboundName": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_.]+$"
        },
        "inboundMultiplicity": {
          "type": "string",
          "enum": [
            "ZeroOrOne",
            "One",
            "N"
          ]
        },
        "outboundMultiplicity": {
          "type": "string",
          "enum": [
            "ZeroOrOne",
            "One",
            "N"
          ]
        },
        "attributes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[a-zA-Z0-9-_.]+/[a-zA-Z0-9-_.]+$"
              },
              "name": {
                "type": "string",
                "pattern": "^[a-zA-Z0-9_.]+$"
              },
              "isAutoCompleteEnabled": {
                "type": "boolean",
                "$comment": "If true, the attribute uses auto complete."
              },
              "autoCompleteFilter": {
                "type": "string",
                "$comment": "The filter for auto complete defined by a regex expression."
              },
              "autoCompleteLimit": {
                "type": "integer",
                "$comment": "The amount of entries in auto complete filter."
              },
              "autoIncrementReference": {
                "type": "string",
                "$comment": "The reference to the attribute that is used for auto increment."
              }
            },
            "additionalProperties": false,
            "required": [
              "id",
              "name"
            ]
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "id",
        "inboundName",
        "outboundName",
        "inboundMultiplicity",
        "outboundMultiplicity"
      ]
    }
  }
}