{
  "$id": "https://schemas.meshmakers.cloud/construction-kit-elements-attribute.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "CkAttribute": {
      "type": "object",
      "title": "CkAttribute",
      "description": "A construction kit attribute definition",
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9-_.]+$"
        },
        "valueType": {
          "type": "string",
          "enum": [
            "String",
            "Boolean",
            "DateTime",
            "Int",
            "Double",
            "StringArray",
            "IntArray",
            "Record",
            "RecordArray"
          ]
        },
        "valueCkRecordId": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9-_.]+/[a-zA-Z0-9-_.]+$"
        },
        "defaultValues": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "selectionValues": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "key": {
                "type": "integer"
              },
              "name": {
                "type": "string"
              }
            },
            "additionalProperties": false,
            "required": [
              "key",
              "name"
            ]
          }
        },
        "isOptional": {
          "type": "boolean"
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "id",
        "valueType"
      ]
    }
  }
}