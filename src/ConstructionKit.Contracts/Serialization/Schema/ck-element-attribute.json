{
  "$id": "https://schemas.meshmakers.cloud/construction-kit-elements-attribute.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "CkTypeAttribute":{
      "type": "object",
      "title": "CkTypeAttribute",
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9-_.]+/[a-zA-Z0-9-_.]+$"
        },
        "name": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_.]+$"
        },
        "autoCompleteValues": {
          "type": "array",
          "$comment": "A list of values that are used for auto completion.",
          "items": {
            "type": "string"
          }
        },
        "isOptional": {
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "required": [
        "id",
        "name"
      ]
    },
    "CkAttribute": {
      "type": "object",
      "title": "CkAttribute",
      "description": "A construction kit attribute definition",
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9-_.]+$"
        },
        "valueType": {
          "type": "string",
          "enum": [
            "String",
            "Boolean",
            "DateTime",
            "Int",
            "Double",
            "StringArray",
            "IntArray",
            "Record",
            "RecordArray",
            "TimeSpan",
            "Enum",
            "Int64",
            "DateTimeOffset"
          ]
        },
        "valueCkRecordId": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9-_.]+/[a-zA-Z0-9-_.]+$"
        },
        "valueCkEnumId": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9-_.]+/[a-zA-Z0-9-_.]+$"
        },
        "defaultValues": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "id",
        "valueType"
      ]
    }
  }
}