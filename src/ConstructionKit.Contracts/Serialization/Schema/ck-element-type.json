{
  "$id": "https://schemas.meshmakers.cloud/construction-kit-elements-type.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "CkType": {
      "type": "object",
      "title": "CkType",
      "description": "A construction kit type definition",
      "properties": {
        "typeId": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9-_.]+$"
        },
        "derivedFromCkTypeId": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9-_.]+/[a-zA-Z0-9-_.]+$"
        },
        "isFinal": {
          "type": "boolean"
        },
        "isAbstract": {
          "type": "boolean"
        },
        "attributes": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "https://schemas.meshmakers.cloud/construction-kit-elements-attribute.schema.json#/definitions/CkTypeAttribute"
          }
        },
        "indexes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "indexType": {
                "type": "string",
                "enum": [
                  "None",
                  "Ascending",
                  "Text"
                ]
              },
              "language": {
                "type": "string"
              },
              "fields": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "weight": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "attributeNames": {
                      "type": "array",
                      "items": {
                        "type": "string",
                        "pattern": "^[a-zA-Z0-9_.]+$"
                      }
                    }
                  },
                  "additionalProperties": false,
                  "required": [
                    "attributeNames"
                  ]
                }
              }
            },
            "additionalProperties": false,
            "required": [
              "indexType"
            ]
          }
        },
        "associations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[a-zA-Z0-9_.]+/[a-zA-Z0-9_.]+$"
              },
              "targetCkTypeId": {
                "type": "string",
                "pattern": "^[a-zA-Z0-9_.]+/[a-zA-Z0-9_.]+$"
              },
              "targetAttributes":{
                "type": "array",
                "items": {
                  "type": "string",
                  "pattern": "^[a-zA-Z0-9_.]+/[a-zA-Z0-9_.]+$"
                }
              }
            },
            "required": [
              "id",
              "targetCkTypeId"
            ]
          }
        },
        "enableChangeStreamPreAndPostImages": {
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "additionalItems": false,
      "required": [
        "typeId"
      ]
    },
    "CkCompiledType":{
      "type": "object",
      "title": "CkCompiledType",
      "description": "A construction kit compiled type definition",
      "properties": {
        "typeId": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9-_.]+$"
        },
        "derivedFromCkTypeId": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9-_.]+/[a-zA-Z0-9-_.]+$"
        },
        "isFinal": {
          "type": "boolean"
        },
        "isAbstract": {
          "type": "boolean"
        },
        "attributes": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "https://schemas.meshmakers.cloud/construction-kit-elements-attribute.schema.json#/definitions/CkTypeAttribute"
          }
        },
        "indexes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "indexType": {
                "type": "string",
                "enum": [
                  "None",
                  "Ascending",
                  "Text"
                ]
              },
              "language": {
                "type": "string"
              },
              "fields": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "weight": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "attributeNames": {
                      "type": "array",
                      "items": {
                        "type": "string",
                        "pattern": "^[a-zA-Z0-9_.]+$"
                      }
                    }
                  },
                  "additionalProperties": false,
                  "required": [
                    "attributeNames"
                  ]
                }
              }
            },
            "additionalProperties": false,
            "required": [
              "indexType"
            ]
          }
        },
        "associations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[a-zA-Z0-9_.]+/[a-zA-Z0-9_.]+$"
              },
              "targetCkTypeId": {
                "type": "string",
                "pattern": "^[a-zA-Z0-9_.]+/[a-zA-Z0-9_.]+$"
              },
              "targetAttributes":{
                "type": "array",
                "items": {
                  "type": "string",
                  "pattern": "^[a-zA-Z0-9_.]+/[a-zA-Z0-9_.]+$"
                }
              }
            },
            "required": [
              "id",
              "targetCkTypeId"
            ]
          }
        },
        "enableChangeStreamPreAndPostImages": {
          "type": "boolean"
        },
        "isCollectionRoot": {
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "additionalItems": false
    }
  }
}
