{
  "$id": "https://schemas.meshmakers.cloud/construction-kit-compiled.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri"
    },
    "modelId": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9-.]+$"
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-zA-Z0-9-.]+$"
      }
    },
    "description": {
      "type": "string"
    },
    "attributes": {
      "type": "array",
      "items": {
        "type": "object",
        "$ref": "https://schemas.meshmakers.cloud/construction-kit-elements-attribute.schema.json#/definitions/CkAttribute"
      }
    },
    "types": {
      "type": "array",
      "items": {
        "type": "object",
        "$ref": "https://schemas.meshmakers.cloud/construction-kit-elements-type.schema.json#/definitions/CkCompiledType"
      }
    },
    "associationRoles": {
      "type": "array",
      "items": {
        "type": "object",
        "$ref": "https://schemas.meshmakers.cloud/construction-kit-elements-associationRole.schema.json#/definitions/CkAssociationRole"
      }
    },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "$ref": "https://schemas.meshmakers.cloud/construction-kit-elements-record.schema.json#/definitions/CkRecord"
      }
    },
    "enums": {
      "type": "array",
      "items": {
        "type": "object",
        "$ref": "https://schemas.meshmakers.cloud/construction-kit-elements-enum.schema.json#/definitions/CkEnum"
      }
    },
    "migrations": {
      "type": "object",
      "properties": {
        "meta": {
          "$ref": "https://schemas.meshmakers.cloud/ck-migration-meta.schema.json#/definitions/CkMigrationMeta"
        },
        "scripts": {
          "type": "array",
          "items": {
            "$ref": "https://schemas.meshmakers.cloud/ck-migration.schema.json#/definitions/CkMigrationScript"
          }
        }
      },
      "additionalProperties": false,
      "required": ["meta"]
    }
  },
  "additionalProperties": false,
  "required": [
    "modelId"
  ]
}