{
  "$id": "https://schemas.meshmakers.cloud/construction-kit-elements-associationRole.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "definitions": {
    "CkAssociationRole": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9-_.]+$"
        },
        "inboundName": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_]+$"
        },
        "outboundName": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_]+$"
        },
        "inboundMultiplicity": {
          "type": "string",
          "enum": [
            "ZeroOrOne",
            "One",
            "N"
          ]
        },
        "outboundMultiplicity": {
          "type": "string",
          "enum": [
            "ZeroOrOne",
            "One",
            "N"
          ]
        },
        "attributes": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "https://schemas.meshmakers.cloud/construction-kit-elements-attribute.schema.json#/definitions/CkTypeAttribute"
          }
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "id",
        "inboundName",
        "outboundName",
        "inboundMultiplicity",
        "outboundMultiplicity"
      ]
    }
  }
}