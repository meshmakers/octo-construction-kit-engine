{
  "$id": "https://schemas.meshmakers.cloud/construction-kit-elements-associationRole.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "definitions": {
    "CkAssociationRole": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Z][a-zA-Z0-9_]*(?:\\.[A-Z][a-zA-Z0-9_]*)*(?:-\\d+)?$",
          "description": "Association role identifier in Pascal Case with optional namespace (e.g., 'ParentChild', 'Machine_OrderAssignment', 'Related-1')"
        },
        "inboundName": {
          "type": "string",
          "pattern": "^[A-Z][a-zA-Z0-9]*$",
          "description": "Inbound navigation name in Pascal Case (e.g., 'Children', 'RelatesFrom')"
        },
        "outboundName": {
          "type": "string",
          "pattern": "^[A-Z][a-zA-Z0-9]*$",
          "description": "Outbound navigation name in Pascal Case (e.g., 'Parent', 'RelatesTo')"
        },
        "inboundMultiplicity": {
          "type": "string",
          "enum": [
            "ZeroOrOne",
            "One",
            "N"
          ]
        },
        "outboundMultiplicity": {
          "type": "string",
          "enum": [
            "ZeroOrOne",
            "One",
            "N"
          ]
        },
        "attributes": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "https://schemas.meshmakers.cloud/construction-kit-elements-attribute.schema.json#/definitions/CkTypeAttribute"
          }
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "id",
        "inboundName",
        "outboundName",
        "inboundMultiplicity",
        "outboundMultiplicity"
      ]
    }
  }
}