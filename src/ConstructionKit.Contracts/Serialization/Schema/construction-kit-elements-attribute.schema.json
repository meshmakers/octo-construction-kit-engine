{
  "$id": "https://schemas.meshmakers.cloud/construction-kit-elements-attribute.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "definitions": {
    "CkTypeAttribute": {
      "type": "object",
      "title": "CkTypeAttribute",
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^(?:[A-Z][a-zA-Z0-9_]*(?:\\.[A-Z][a-zA-Z0-9_]*)*|[a-zA-Z][a-zA-Z0-9._-]*|\\$\\{[a-zA-Z0-9_.]+\\})/[A-Z][a-zA-Z0-9_]*(?:\\.[A-Z][a-zA-Z0-9_]*)*(?:-\\d+)?$",
          "description": "Attribute reference in Pascal Case (e.g., '${this}/Name')"
        },
        "name": {
          "type": "string",
          "pattern": "^[A-Z][a-zA-Z0-9]*$",
          "description": "Attribute name in Pascal Case (e.g., 'Name', 'AttributePath')"
        },
        "autoIncrementReference": {
          "type": "string"
        },
        "autoCompleteValues": {
          "type": "array",
          "$comment": "A list of values that are used for auto completion.",
          "items": {
            "type": "string"
          }
        },
        "isOptional": {
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "required": [
        "id",
        "name"
      ]
    },
    "CkAttribute": {
      "type": "object",
      "title": "CkAttribute",
      "description": "A construction kit attribute definition",
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Z][a-zA-Z0-9_]*(?:\\.[A-Z][a-zA-Z0-9_]*)*(?:-\\d+)?$",
          "description": "Attribute identifier in Pascal Case, optionally with namespace and version (e.g., 'Name', 'Query.Filter-1')"
        },
        "valueType": {
          "type": "string",
          "enum": [
            "String",
            "Boolean",
            "DateTime",
            "Int",
            "Double",
            "StringArray",
            "IntArray",
            "Record",
            "RecordArray",
            "TimeSpan",
            "Enum",
            "Int64",
            "DateTimeOffset",
            "Binary",
            "BinaryLinked",
            "GeospatialPoint"
          ]
        },
        "valueCkRecordId": {
          "type": "string",
          "pattern": "^(?:[A-Z][a-zA-Z0-9_]*(?:\\.[A-Z][a-zA-Z0-9_]*)*|[a-zA-Z][a-zA-Z0-9._-]*|\\$\\{[a-zA-Z0-9_.]+\\})/[A-Z][a-zA-Z0-9_]*(?:\\.[A-Z][a-zA-Z0-9_]*)*(?:-\\d+)?$",
          "description": "Record type reference in Pascal Case (e.g., '${this}/FieldFilter')"
        },
        "valueCkEnumId": {
          "type": "string",
          "pattern": "^(?:[A-Z][a-zA-Z0-9_]*(?:\\.[A-Z][a-zA-Z0-9_]*)*|[a-zA-Z][a-zA-Z0-9._-]*|\\$\\{[a-zA-Z0-9_.]+\\})/[A-Z][a-zA-Z0-9_]*(?:\\.[A-Z][a-zA-Z0-9_]*)*(?:-\\d+)?$",
          "description": "Enum type reference in Pascal Case (e.g., '${this}/TokenType')"
        },
        "defaultValues": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "boolean"
              },
              {
                "type": "number"
              }
            ]
          }
        },
        "description": {
          "type": "string"
        },
        "metaData": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "key": {
                "type": "string"
              },
              "value": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "boolean"
                  },
                  {
                    "type": "number"
                  }
                ]
              },
              "description": {
                "type": "string"
              }
            },
            "additionalProperties": false,
            "required": [
              "key"
            ]
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "id",
        "valueType"
      ]
    }
  }
}