{
  "$id": "https://schemas.meshmakers.cloud/construction-kit-elements-attribute.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "definitions": {
    "CkTypeAttribute": {
      "type": "object",
      "title": "CkTypeAttribute",
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^(?:[a-zA-Z0-9-_.]+|\\$\\{[a-zA-Z0-9]+\\})/[a-zA-Z0-9-_.]+$"
        },
        "name": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_]+$"
        },
        "autoIncrementReference": {
          "type": "string"
        },
        "autoCompleteValues": {
          "type": "array",
          "$comment": "A list of values that are used for auto completion.",
          "items": {
            "type": "string"
          }
        },
        "isOptional": {
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "required": [
        "id",
        "name"
      ]
    },
    "CkAttribute": {
      "type": "object",
      "title": "CkAttribute",
      "description": "A construction kit attribute definition",
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9-_.]+$"
        },
        "valueType": {
          "type": "string",
          "enum": [
            "String",
            "Boolean",
            "DateTime",
            "Int",
            "Double",
            "StringArray",
            "IntArray",
            "Record",
            "RecordArray",
            "TimeSpan",
            "Enum",
            "Int64",
            "DateTimeOffset",
            "Binary",
            "BinaryLinked",
            "GeospatialPoint"
          ]
        },
        "valueCkRecordId": {
          "type": "string",
          "pattern": "^(?:[a-zA-Z0-9-_.]+|\\$\\{[a-zA-Z0-9]+\\})/[a-zA-Z0-9-_.]+$"
        },
        "valueCkEnumId": {
          "type": "string",
          "pattern": "^(?:[a-zA-Z0-9-_.]+|\\$\\{[a-zA-Z0-9]+\\})/[a-zA-Z0-9-_.]+$"
        },
        "defaultValues": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "boolean"
              },
              {
                "type": "number"
              }
            ]
          }
        },
        "description": {
          "type": "string"
        },
        "metaData": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "key": {
                "type": "string"
              },
              "value": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "boolean"
                  },
                  {
                    "type": "number"
                  }
                ]
              },
              "description": {
                "type": "string"
              }
            },
            "additionalProperties": false,
            "required": [
              "key"
            ]
          }
        },
        "isDataStream": {
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "required": [
        "id",
        "valueType"
      ]
    }
  }
}