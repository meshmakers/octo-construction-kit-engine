{
  "$id": "https://schemas.meshmakers.cloud/construction-kit-elements-enum.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "definitions": {
    "CkEnum": {
      "type": "object",
      "title": "CkEnum",
      "description": "A construction kit enum definition, used at attribute types",
      "properties": {
        "enumId": {
          "type": "string",
          "pattern": "^[A-Z][a-zA-Z0-9_]*(?:\\.[A-Z][a-zA-Z0-9_]*)*(?:-\\d+)?$",
          "description": "Enum identifier in Pascal Case with optional namespace (e.g., 'FieldFilterOperator', 'Widget.Type', 'TokenType-1')"
        },
        "values": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "key": {
                "type": "integer"
              },
              "name": {
                "type": "string",
                "pattern": "^[A-Z][a-zA-Z0-9]*$",
                "description": "Enum value name in Pascal Case (e.g., 'Equals', 'NotEquals')"
              },
              "description": {
                "type": "string"
              },
              "isExtension": {
                "type": "boolean"
              }
            },
            "additionalProperties": false,
            "required": [
              "key",
              "name"
            ]
          }
        },
        "useFlags": {
          "type": "boolean"
        },
        "isExtensible": {
          "type": "boolean"
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "enumId"
      ]
    }
  }
}
