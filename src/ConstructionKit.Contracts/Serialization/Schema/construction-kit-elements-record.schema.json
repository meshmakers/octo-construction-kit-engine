{
  "$id": "https://schemas.meshmakers.cloud/construction-kit-elements-record.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "definitions": {
    "CkRecord": {
      "type": "object",
      "title": "CkRecord",
      "description": "A construction kit record definition, used at attribute types",
      "properties": {
        "recordId": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9-_.]+$"
        },
        "derivedFromCkRecordId": {
          "type": "string",
          "pattern": "^(?:[a-zA-Z0-9-_.]+|\\$\\{[a-zA-Z0-9]+\\})/[a-zA-Z0-9-_.]+$"
        },
        "isFinal": {
          "type": "boolean"
        },
        "isAbstract": {
          "type": "boolean"
        },
        "attributes": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "https://schemas.meshmakers.cloud/construction-kit-elements-attribute.schema.json#/definitions/CkTypeAttribute"
          }
        },
        "enableChangeStreamPreAndPostImages": {
          "type": "boolean"
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "additionalItems": false,
      "required": [
        "recordId"
      ]
    }
  }
}
