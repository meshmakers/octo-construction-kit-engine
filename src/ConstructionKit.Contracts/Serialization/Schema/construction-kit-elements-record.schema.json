{
  "$id": "https://schemas.meshmakers.cloud/construction-kit-elements-record.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "definitions": {
    "CkRecord": {
      "type": "object",
      "title": "CkRecord",
      "description": "A construction kit record definition, used at attribute types",
      "properties": {
        "recordId": {
          "type": "string",
          "pattern": "^[A-Z][a-zA-Z0-9_]*(?:\\.[A-Z][a-zA-Z0-9_]*)*(?:-\\d+)?$",
          "description": "Record identifier in Pascal Case with optional namespace (e.g., 'FieldFilter', 'Theme.Colors', 'FieldFilter-1')"
        },
        "derivedFromCkRecordId": {
          "type": "string",
          "pattern": "^(?:[A-Z][a-zA-Z0-9_]*(?:\\.[A-Z][a-zA-Z0-9_]*)*|[a-zA-Z][a-zA-Z0-9._-]*|\\$\\{[a-zA-Z0-9_.]+\\})/[A-Z][a-zA-Z0-9_]*(?:\\.[A-Z][a-zA-Z0-9_]*)*(?:-\\d+)?$",
          "description": "Reference to base record in Pascal Case (e.g., '${this}/BaseRecord')"
        },
        "isFinal": {
          "type": "boolean"
        },
        "isAbstract": {
          "type": "boolean"
        },
        "attributes": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "https://schemas.meshmakers.cloud/construction-kit-elements-attribute.schema.json#/definitions/CkTypeAttribute"
          }
        },
        "enableChangeStreamPreAndPostImages": {
          "type": "boolean"
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "recordId"
      ]
    }
  }
}
