{
  "$id": "https://schemas.meshmakers.cloud/construction-kit-elements-type.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "definitions": {
    "CkType": {
      "type": "object",
      "title": "CkType",
      "description": "A construction kit type definition",
      "properties": {
        "typeId": {
          "type": "string",
          "pattern": "^[A-Z][a-zA-Z0-9_]*(?:\\.[A-Z][a-zA-Z0-9_]*)*(?:-\\d+)?$",
          "description": "Type identifier in Pascal Case with optional namespace (e.g., 'Entity', 'Photovoltaic.Module', 'Entity-1')"
        },
        "derivedFromCkTypeId": {
          "type": "string",
          "pattern": "^(?:[A-Z][a-zA-Z0-9_]*(?:\\.[A-Z][a-zA-Z0-9_]*)*|[a-zA-Z][a-zA-Z0-9._-]*|\\$\\{[a-zA-Z0-9_.]+\\})/[A-Z][a-zA-Z0-9_]*(?:\\.[A-Z][a-zA-Z0-9_]*)*(?:-\\d+)?$",
          "description": "Reference to base type in Pascal Case (e.g., '${this}/Entity')"
        },
        "isFinal": {
          "type": "boolean"
        },
        "isAbstract": {
          "type": "boolean"
        },
        "description": {
          "type": "string"
        },
        "attributes": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "https://schemas.meshmakers.cloud/construction-kit-elements-attribute.schema.json#/definitions/CkTypeAttribute"
          }
        },
        "indexes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "indexType": {
                "type": "string",
                "enum": [
                  "None",
                  "Ascending",
                  "Text",
                  "Unique",
                  "UniqueNotDeleted"
                ]
              },
              "language": {
                "type": "string"
              },
              "fields": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "weight": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "attributePaths": {
                      "type": "array",
                      "items": {
                        "type": "string",
                        "pattern": "^[a-zA-Z0-9_.]+$"
                      }
                    }
                  },
                  "additionalProperties": false,
                  "required": [
                    "attributePaths"
                  ]
                }
              }
            },
            "additionalProperties": false,
            "required": [
              "indexType"
            ]
          }
        },
        "associations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^(?:[A-Z][a-zA-Z0-9_]*(?:\\.[A-Z][a-zA-Z0-9_]*)*|[a-zA-Z][a-zA-Z0-9._-]*|\\$\\{[a-zA-Z0-9_.]+\\})/[A-Z][a-zA-Z0-9_]*(?:\\.[A-Z][a-zA-Z0-9_]*)*(?:-\\d+)?$",
                "description": "Association role reference in Pascal Case"
              },
              "targetCkTypeId": {
                "type": "string",
                "pattern": "^(?:[A-Z][a-zA-Z0-9_]*(?:\\.[A-Z][a-zA-Z0-9_]*)*|[a-zA-Z][a-zA-Z0-9._-]*|\\$\\{[a-zA-Z0-9_.]+\\})/[A-Z][a-zA-Z0-9_]*(?:\\.[A-Z][a-zA-Z0-9_]*)*(?:-\\d+)?$",
                "description": "Target type reference in Pascal Case"
              },
              "targetAttributes": {
                "type": "array",
                "items": {
                  "type": "string",
                  "pattern": "^(?:[A-Z][a-zA-Z0-9_]*(?:\\.[A-Z][a-zA-Z0-9_]*)*|[a-zA-Z][a-zA-Z0-9._-]*|\\$\\{[a-zA-Z0-9_.]+\\})/[A-Z][a-zA-Z0-9_]*(?:\\.[A-Z][a-zA-Z0-9_]*)*(?:-\\d+)?$",
                  "description": "Target attribute reference in Pascal Case"
                }
              }
            },
            "required": [
              "id",
              "targetCkTypeId"
            ]
          }
        },
        "enableChangeStreamPreAndPostImages": {
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "required": [
        "typeId"
      ]
    },
    "CkCompiledType": {
      "type": "object",
      "title": "CkCompiledType",
      "description": "A construction kit compiled type definition",
      "properties": {
        "typeId": {
          "type": "string",
          "pattern": "^[A-Z][a-zA-Z0-9_]*(?:\\.[A-Z][a-zA-Z0-9_]*)*(?:-\\d+)?$",
          "description": "Type identifier in Pascal Case with optional namespace (e.g., 'Entity', 'Photovoltaic.Module', 'Entity-1')"
        },
        "derivedFromCkTypeId": {
          "type": "string",
          "pattern": "^(?:[A-Z][a-zA-Z0-9_]*(?:\\.[A-Z][a-zA-Z0-9_]*)*|[a-zA-Z][a-zA-Z0-9._-]*|\\$\\{[a-zA-Z0-9_.]+\\})/[A-Z][a-zA-Z0-9_]*(?:\\.[A-Z][a-zA-Z0-9_]*)*(?:-\\d+)?$",
          "description": "Reference to base type in Pascal Case (e.g., '${this}/Entity')"
        },
        "isFinal": {
          "type": "boolean"
        },
        "isAbstract": {
          "type": "boolean"
        },
        "description": {
          "type": "string"
        },
        "attributes": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "https://schemas.meshmakers.cloud/construction-kit-elements-attribute.schema.json#/definitions/CkTypeAttribute"
          }
        },
        "indexes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "indexType": {
                "type": "string",
                "enum": [
                  "None",
                  "Ascending",
                  "Text",
                  "Unique",
                  "UniqueNotDeleted"
                ]
              },
              "language": {
                "type": "string"
              },
              "fields": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "weight": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "attributePaths": {
                      "type": "array",
                      "items": {
                        "type": "string",
                        "pattern": "^[a-zA-Z0-9_.]+$"
                      }
                    }
                  },
                  "additionalProperties": false,
                  "required": [
                    "attributePaths"
                  ]
                }
              }
            },
            "additionalProperties": false,
            "required": [
              "indexType"
            ]
          }
        },
        "associations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^(?:[A-Z][a-zA-Z0-9_]*(?:\\.[A-Z][a-zA-Z0-9_]*)*|[a-zA-Z][a-zA-Z0-9._-]*|\\$\\{[a-zA-Z0-9_.]+\\})/[A-Z][a-zA-Z0-9_]*(?:\\.[A-Z][a-zA-Z0-9_]*)*(?:-\\d+)?$",
                "description": "Association role reference in Pascal Case"
              },
              "targetCkTypeId": {
                "type": "string",
                "pattern": "^(?:[A-Z][a-zA-Z0-9_]*(?:\\.[A-Z][a-zA-Z0-9_]*)*|[a-zA-Z][a-zA-Z0-9._-]*|\\$\\{[a-zA-Z0-9_.]+\\})/[A-Z][a-zA-Z0-9_]*(?:\\.[A-Z][a-zA-Z0-9_]*)*(?:-\\d+)?$",
                "description": "Target type reference in Pascal Case"
              },
              "targetAttributes": {
                "type": "array",
                "items": {
                  "type": "string",
                  "pattern": "^(?:[A-Z][a-zA-Z0-9_]*(?:\\.[A-Z][a-zA-Z0-9_]*)*|[a-zA-Z][a-zA-Z0-9._-]*|\\$\\{[a-zA-Z0-9_.]+\\})/[A-Z][a-zA-Z0-9_]*(?:\\.[A-Z][a-zA-Z0-9_]*)*(?:-\\d+)?$",
                  "description": "Target attribute reference in Pascal Case"
                }
              }
            },
            "required": [
              "id",
              "targetCkTypeId"
            ]
          }
        },
        "enableChangeStreamPreAndPostImages": {
          "type": "boolean"
        },
        "isCollectionRoot": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    }
  }
}
