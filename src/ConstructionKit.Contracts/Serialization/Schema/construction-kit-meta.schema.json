{
  "$id": "https://schemas.meshmakers.cloud/construction-kit-meta.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri"
    },
    "modelId": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9-.]+$"
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-zA-Z0-9-.]+$"
      }
    },
    "description": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "required": [
    "modelId"
  ]
}