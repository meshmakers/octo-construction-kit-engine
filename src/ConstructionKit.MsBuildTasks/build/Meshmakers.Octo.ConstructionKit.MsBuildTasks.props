<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

    <!--defining properties interesting for my task-->
    <PropertyGroup>
        <!--The folder where the custom task will be present. It points to inside the NuGet package. -->
        <OctoCkCompileTasksFolder Condition="'$(OctoCkCompileTasksFolder)' == '' And '$(MSBuildRuntimeType)'=='Core'">$(MSBuildThisFileDirectory)..\tasks\net10.0</OctoCkCompileTasksFolder>
        <OctoCkCompileTasksFolder Condition="'$(OctoCkCompileTasksFolder)' == '' And '$(MSBuildRuntimeType)'!='Core'">$(MSBuildThisFileDirectory)..\tasks\netstandard2.0</OctoCkCompileTasksFolder>
        <!--Reference to the assembly which contains the MSBuild Task-->
        <OctoCkCompileTasksAssembly>$(OctoCkCompileTasksFolder)\$(MSBuildThisFileName).dll</OctoCkCompileTasksAssembly>
    </PropertyGroup>

    <!--Register our custom task-->
    <UsingTask TaskName="$(MSBuildThisFileName).CkCompile" AssemblyFile="$(OctoCkCompileTasksAssembly)"/>
    <UsingTask TaskName="$(MSBuildThisFileName).CkRestore" AssemblyFile="$(OctoCkCompileTasksAssembly)"/>
    <UsingTask TaskName="$(MSBuildThisFileName).BlueprintEmbed" AssemblyFile="$(OctoCkCompileTasksAssembly)"/>

    <!--Task parameters default values, this can be overridden-->
    <PropertyGroup>
        <OctoCompileCkModel Condition="'$(OctoCompileCkModel)' == ''">true</OctoCompileCkModel>
        <OctoCreateCacheFile Condition="'$(OctoCreateCacheFile)' == ''">true</OctoCreateCacheFile>
        <OctoPublishCkModel Condition="'$(OctoPublishCkModel)' == ''">false</OctoPublishCkModel>
        <OctoPublishCatalog Condition="'$(OctoPublishCatalog)' == ''">LocalFileSystemCatalog</OctoPublishCatalog>
        <OctoLocalCatalogIsEnabled Condition="'$(OctoLocalCatalogIsEnabled)' == ''">true</OctoLocalCatalogIsEnabled>
        <OctoPublicGitHubCatalogIsEnabled Condition="'$(OctoPublicGitHubCatalogIsEnabled)' == ''">true</OctoPublicGitHubCatalogIsEnabled>
        <OctoPrivateGitHubCatalogIsEnabled Condition="'$(OctoPrivateGitHubCatalogIsEnabled)' == ''">true</OctoPrivateGitHubCatalogIsEnabled>
        <OctoGenerateCkModelServiceClass Condition="'$(OctoGenerateCkModelServiceClass)' == ''">true</OctoGenerateCkModelServiceClass>
        <OctoGenerateCkDocumentation Condition="'$(OctoGenerateCkDocumentation)' == ''">false</OctoGenerateCkDocumentation>
        <!--
            Refresh the remote (Public / Private GitHub) catalogs at the start of each CK
            compile. Default true preserves the historical behaviour. Set false on feature/dev
            branches that only consume LocalFs deps populated by sibling projects in the same
            solution build — avoids hammering the shared GitHub PAT's 5000/h rate quota when
            many parallel CI pipelines build at once.
        -->
        <OctoRefreshRemoteCatalogs Condition="'$(OctoRefreshRemoteCatalogs)' == ''">true</OctoRefreshRemoteCatalogs>
    </PropertyGroup>
    <!--Additional Parameters for Generate Docs-->
    <PropertyGroup>
        <OctoCkLinkPath>/docs/technologyGuide/constructionKits/libraries/</OctoCkLinkPath>
    </PropertyGroup>
</Project>