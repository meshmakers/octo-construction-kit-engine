<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

    <!--defining properties interesting for my task-->
    <PropertyGroup>
        <!--The folder where the custom task will be present. It points to inside the NuGet package. -->
        <OctoCkCompileTasksFolder Condition="'$(OctoCkCompileTasksFolder)' == '' And '$(MSBuildRuntimeType)'=='Core'">$(MSBuildThisFileDirectory)..\tasks\net8.0</OctoCkCompileTasksFolder>
        <OctoCkCompileTasksFolder Condition="'$(OctoCkCompileTasksFolder)' == '' And '$(MSBuildRuntimeType)'!='Core'">$(MSBuildThisFileDirectory)..\tasks\netstandard2.0</OctoCkCompileTasksFolder>
        <!--Reference to the assembly which contains the MSBuild Task-->
        <OctoCkCompileTasksAssembly>$(OctoCkCompileTasksFolder)\$(MSBuildThisFileName).dll</OctoCkCompileTasksAssembly>
    </PropertyGroup>

    <!--Register our custom task-->
    <UsingTask TaskName="$(MSBuildThisFileName).CkCompile" AssemblyFile="$(OctoCkCompileTasksAssembly)"/>
    <UsingTask TaskName="$(MSBuildThisFileName).CkRestore" AssemblyFile="$(OctoCkCompileTasksAssembly)"/>

    <!--Task parameters default values, this can be overridden-->
    <PropertyGroup>
        <OctoCompileCkModel Condition="'$(OctoCompileCkModel)' == ''">true</OctoCompileCkModel>
        <OctoCreateCacheFile Condition="'$(OctoCreateCacheFile)' == ''">true</OctoCreateCacheFile>
        <OctoPublishCkModel Condition="'$(OctoPublishCkModel)' == ''">false</OctoPublishCkModel>
        <OctoGenerateCkModelServiceClass Condition="'$(OctoGenerateCkModelServiceClass)' == ''">true</OctoGenerateCkModelServiceClass>
        <OctoGenerateCkDocumentation Condition="'$(OctoGenerateCkDocumentation)' == ''">false</OctoGenerateCkDocumentation>
    </PropertyGroup>
    <!--Additional Parameters for Generate Docs-->
    <PropertyGroup>
        <OctoCkLinkPath>/docs/technologyGuide/constructionKits/</OctoCkLinkPath>
        <OctoCkVersion>1.0</OctoCkVersion>
    </PropertyGroup>
</Project>