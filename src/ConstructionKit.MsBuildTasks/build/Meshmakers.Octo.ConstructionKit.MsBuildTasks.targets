<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
    <PropertyGroup>
        <OctoCkCompileOutputImportFolder Condition="'$(OctoCkCompileOutputImportFolder)' == ''">$(OutputPath)octo-ck-libraries/$(ProjectName)/imports</OctoCkCompileOutputImportFolder>
        <OctoCkCompileCacheImportFolder Condition="'$(OctoCkCompileCacheImportFolder)' == ''">$(IntermediateOutputPath)octo-ck-cache/$(ProjectName)/imports</OctoCkCompileCacheImportFolder>
        <OctoCkCompileOutputCompilerFolder Condition="'$(OctoCkCompileOutputCompilerFolder)' == ''">$(OutputPath)octo-ck-libraries/$(ProjectName)/out</OctoCkCompileOutputCompilerFolder>
        <OctoCkCompileCacheCompileFolder Condition="'$(OctoCkCompileCacheCompileFolder)' == ''">$(IntermediateOutputPath)octo-ck-cache/$(ProjectName)/out</OctoCkCompileCacheCompileFolder>
    </PropertyGroup>
    
    <!--Defining all the text files input parameters-->
    <ItemGroup>
        <ConstructionKitConfigFile Include="$(MSBuildProjectDirectory)/construction-kits.yaml"/>
    </ItemGroup>

    <Target Name="GatherCompileFiles">
        <ItemGroup>
            <ConstructionKitFolderInputCompileFiles Include="@(ConstructionKitFolder->'%(Identity)/**/*.yaml')" />
            <ConstructionKitFolderOutCompileFiles Include="$(OctoCkCompileOutputCompilerFolder);$(OctoCkCompileOutputCompilerFolder)/*.yaml"/>
        </ItemGroup>
    </Target>

    <Target Name="GatherImportFiles">
        <ItemGroup>
            <ConstructionKitFolderInputImportFiles Include="@(ConstructionKitConfigFile)" />
            <ConstructionKitFolderOutImportFiles Include="$(OctoCkCompileOutputImportFolder);$(OctoCkCompileOutputImportFolder)/*.yaml"/>
        </ItemGroup>
    </Target>
    
    <!--It is generated a target which is executed before the compilation-->
    <Target Name="CkCompile"
            AfterTargets="ResolveProjectReferences"
            BeforeTargets="CoreCompile;CoreGenerateMSBuildEditorConfigFileShouldRun"
            Inputs="@(ConstructionKitFolderInputCompileFiles)"
            Outputs="@(ConstructionKitFolderOutCompileFiles)"
            DependsOnTargets="GatherCompileFiles"
            Condition="'@(ConstructionKitFolder)' != '' AND ('$(OctoPublishCkModel)' == 'true' OR '$(OctoCompileCkModel)' == 'true')">

        <Message Importance="High" Text="Building construction kit (target framework $(TargetFramework)) -> $(OctoCkCompileOutputCompilerFolder)" />
        <Message Importance="High" Text="Location of OctoMesh compiler package: '$(MSBuildThisFileDirectory)'"/>
        <!--Calling our custom task-->
        <CkCompile ConstructionKitFolders="@(ConstructionKitFolder)"
                   OutputPath="$(OctoCkCompileOutputCompilerFolder)"
                   CacheFilePath="$(OctoCkCompileCacheCompileFolder)"
                   Compile="$(OctoCompileCkModel)"
                   PublishCkModel="$(OctoPublishCkModel)"
                   PublishCatalogName="$(OctoPublishCatalog)"
                   IsLocalCatalogEnabled="$(OctoLocalCatalogIsEnabled)"
                   GenerateCkDocumentation="$(OctoGenerateCkDocumentation)"
                   CkLinkPath="$(OctoCkLinkPath)">
            <Output TaskParameter="CompiledModelFiles" PropertyName="CompiledModelFiles" />
            <Output TaskParameter="CacheFiles" PropertyName="CacheFiles" />
        </CkCompile>

        <!-- Add AdditionalFiles immediately after compilation -->
        <ItemGroup>
            <AdditionalFiles Include="$(OctoCkCompileCacheCompileFolder)/*.json" />
        </ItemGroup>

        <!-- Add EmbeddedResource files immediately after compilation -->
        <ItemGroup>
            <_OctoCompilerResourceFilesNew Include="$(OctoCkCompileOutputCompilerFolder)/*.yaml" Exclude="@(_OctoCompilerResourceFiles)" />
            <EmbeddedResource Include="@(_OctoCompilerResourceFilesNew)">
                <LogicalName>$(RootNamespace).%(Filename)%(Extension)</LogicalName>
                <Visible>False</Visible>
                <GenerateCkModelServiceClass>$(OctoGenerateCkModelServiceClass)</GenerateCkModelServiceClass>
            </EmbeddedResource>
            <_OctoCompilerResourceFiles Include="@(_OctoCompilerResourceFilesNew)" />
        </ItemGroup>
    </Target>

    <Target Name="CkRestore"
            AfterTargets="ResolveProjectReferences"
            BeforeTargets="CoreCompile;CoreGenerateMSBuildEditorConfigFileShouldRun"
            DependsOnTargets="GatherImportFiles"
            Condition="'@(ConstructionKitConfigFile)' != '' OR '@(ConstructionKitFolder)' != ''">
        <!--Calling our custom task-->
        <Message Condition="Exists(%(ConstructionKitConfigFile.Identity))" Importance="High" Text="Restoring construction kit model libraries %(ConstructionKitConfigFile.Identity)"/>
        <CkRestore ConstructionKitModelConfigFiles="@(ConstructionKitConfigFile)"
                   IsLocalCatalogEnabled="$(OctoLocalCatalogIsEnabled)"
                   OutputPath="$(OctoCkCompileOutputImportFolder)"
                   CacheFilePath="$(OctoCkCompileCacheImportFolder)">
            <Output TaskParameter="CompiledModelFiles" ItemName="CompiledModelFiles" />
            <Output TaskParameter="CacheFiles" ItemName="CacheFiles" />
        </CkRestore>

        <!-- Add AdditionalFiles immediately after restore -->
        <ItemGroup>
            <AdditionalFiles Include="$(OctoCkCompileCacheImportFolder)/*.json" />
        </ItemGroup>

        <!-- Add EmbeddedResource files immediately after restore -->
        <ItemGroup>
            <_OctoImportResourceFilesNew Include="$(OctoCkCompileOutputImportFolder)/*.yaml" Exclude="@(_OctoImportResourceFiles)" />
            <EmbeddedResource Include="@(_OctoImportResourceFilesNew)">
                <LogicalName>$(RootNamespace).%(Filename)%(Extension)</LogicalName>
                <Visible>False</Visible>
                <GenerateCkModelServiceClass>$(OctoGenerateCkModelServiceClass)</GenerateCkModelServiceClass>
            </EmbeddedResource>
            <_OctoImportResourceFiles Include="@(_OctoImportResourceFilesNew)" />
        </ItemGroup>
    </Target>

    <!--
        Note: EmbeddedResource and AdditionalFiles are now added directly in CkCompile and CkRestore targets
        immediately after the files are created. This ensures:
        1. Files exist before being added to the build
        2. AdditionalFiles are available for SourceGenerators during CoreCompile
        3. Items are added before Source Generators are initialized
        4. Incremental builds work correctly
    -->

</Project>