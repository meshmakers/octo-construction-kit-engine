<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
    <PropertyGroup>
        <OctoCkCompileOutputImportFolder Condition="'$(OctoCkCompileOutputImportFolder)' == ''">$(OutputPath)octo-ck-libraries/$(ProjectName)/imports</OctoCkCompileOutputImportFolder>
        <OctoCkCompileCacheImportFolder Condition="'$(OctoCkCompileCacheImportFolder)' == ''">$(IntermediateOutputPath)octo-ck-cache/$(ProjectName)/imports</OctoCkCompileCacheImportFolder>
        <OctoCkCompileOutputCompilerFolder Condition="'$(OctoCkCompileOutputCompilerFolder)' == ''">$(OutputPath)octo-ck-libraries/$(ProjectName)/out</OctoCkCompileOutputCompilerFolder>
        <OctoCkCompileCacheCompileFolder Condition="'$(OctoCkCompileCacheCompileFolder)' == ''">$(IntermediateOutputPath)octo-ck-cache/$(ProjectName)/out</OctoCkCompileCacheCompileFolder>
    </PropertyGroup>
    
    <!--Defining all the text files input parameters-->
    <ItemGroup>
        <ConstructionKitConfigFile Include="$(MSBuildProjectDirectory)/construction-kits.yaml"/>
    </ItemGroup>

    <Target Name="GatherCompileFiles">
        <ItemGroup>
            <ConstructionKitFolderInputCompileFiles Include="@(ConstructionKitFolder->'%(Identity)/**/*.yaml')" />
            <!-- Include the compiler assembly itself as an input so engine/schema updates invalidate stale outputs. -->
            <ConstructionKitFolderInputCompileFiles Include="$(OctoCkCompileTasksAssembly)" />
            <!-- The bare directory entry on the left of the semicolon is intentional: it forces CkCompile to re-run
                 every build (the incremental check sees a "missing file" for the directory path), which keeps the
                 EmbeddedResource + AdditionalFiles added inside CkCompile's body present on every invocation. A
                 cleaner "file-only" outputs list correctly fixes the incremental check, but then the SourceGenerator
                 has no AdditionalFiles inputs on the rebuild-skipped path and the generated types vanish from the
                 model DLLs (regression observed in octo-construction-kit-engine-CI build 33240). The duplicate
                 execution from GeneratePackageOnBuild's Pack target is handled by gating OctoPublishCkModel on
                 _IsPacking != 'true' in the consuming csproj (see SystemCommunicationCkModel.csproj), and by the
                 60 s Octokit timeout in GitHubClientWrapper so even an unguarded re-run fails fast. -->
            <ConstructionKitFolderOutCompileFiles Include="$(OctoCkCompileOutputCompilerFolder);$(OctoCkCompileOutputCompilerFolder)/*.yaml"/>
        </ItemGroup>
    </Target>

    <Target Name="GatherImportFiles">
        <ItemGroup>
            <ConstructionKitFolderInputImportFiles Include="@(ConstructionKitConfigFile)" />
            <!-- Include the compiler assembly itself as an input so engine/schema updates invalidate stale outputs. -->
            <ConstructionKitFolderInputImportFiles Include="$(OctoCkCompileTasksAssembly)" />
            <!-- Bare directory entry retained on purpose; see GatherCompileFiles for the source-gen rationale. -->
            <ConstructionKitFolderOutImportFiles Include="$(OctoCkCompileOutputImportFolder);$(OctoCkCompileOutputImportFolder)/*.yaml"/>
        </ItemGroup>
    </Target>
    
    <!--It is generated a target which is executed before the compilation-->
    <Target Name="CkCompile"
            AfterTargets="ResolveProjectReferences"
            BeforeTargets="CoreCompile;CoreGenerateMSBuildEditorConfigFileShouldRun"
            Inputs="@(ConstructionKitFolderInputCompileFiles)"
            Outputs="@(ConstructionKitFolderOutCompileFiles)"
            DependsOnTargets="GatherCompileFiles"
            Condition="'@(ConstructionKitFolder)' != '' AND ('$(OctoPublishCkModel)' == 'true' OR '$(OctoCompileCkModel)' == 'true')">

        <Message Importance="High" Text="Building construction kit (target framework $(TargetFramework)) -> $(OctoCkCompileOutputCompilerFolder)" />
        <Message Importance="High" Text="Location of OctoMesh compiler package: '$(MSBuildThisFileDirectory)'"/>
        <!--Calling our custom task-->
        <CkCompile ConstructionKitFolders="@(ConstructionKitFolder)"
                   OutputPath="$(OctoCkCompileOutputCompilerFolder)"
                   CacheFilePath="$(OctoCkCompileCacheCompileFolder)"
                   Compile="$(OctoCompileCkModel)"
                   PublishCkModel="$(OctoPublishCkModel)"
                   PublishCatalogName="$(OctoPublishCatalog)"
                   IsLocalCatalogEnabled="$(OctoLocalCatalogIsEnabled)"
                   IsPublicGitHubCatalogEnabled="$(OctoPublicGitHubCatalogIsEnabled)"
                   IsPrivateGitHubCatalogEnabled="$(OctoPrivateGitHubCatalogIsEnabled)"
                   PrivateGitHubApiKey="$(OctoPrivateGitHubApiKey)"
                   PublicGitHubApiKey="$(OctoPublicGitHubApiKey)"
                   GenerateCkDocumentation="$(OctoGenerateCkDocumentation)"
                   CkLinkPath="$(OctoCkLinkPath)"
                   RefreshRemoteCatalogs="$(OctoRefreshRemoteCatalogs)">
            <Output TaskParameter="CompiledModelFiles" PropertyName="CompiledModelFiles" />
            <Output TaskParameter="CacheFiles" PropertyName="CacheFiles" />
        </CkCompile>

        <!-- Add AdditionalFiles immediately after compilation -->
        <ItemGroup>
            <AdditionalFiles Include="$(OctoCkCompileCacheCompileFolder)/*.json" />
        </ItemGroup>

        <!-- Add EmbeddedResource files immediately after compilation -->
        <ItemGroup>
            <_OctoCompilerResourceFilesNew Include="$(OctoCkCompileOutputCompilerFolder)/*.yaml" Exclude="@(_OctoCompilerResourceFiles)" />
            <EmbeddedResource Include="@(_OctoCompilerResourceFilesNew)">
                <LogicalName>$(RootNamespace).%(Filename)%(Extension)</LogicalName>
                <Visible>False</Visible>
                <GenerateCkModelServiceClass>$(OctoGenerateCkModelServiceClass)</GenerateCkModelServiceClass>
            </EmbeddedResource>
            <_OctoCompilerResourceFiles Include="@(_OctoCompilerResourceFilesNew)" />
        </ItemGroup>
    </Target>

    <Target Name="CkRestore"
            AfterTargets="ResolveProjectReferences"
            BeforeTargets="CoreCompile;CoreGenerateMSBuildEditorConfigFileShouldRun"
            DependsOnTargets="GatherImportFiles"
            Condition="'@(ConstructionKitConfigFile)' != '' OR '@(ConstructionKitFolder)' != ''">
        <!--Calling our custom task-->
        <Message Condition="Exists(%(ConstructionKitConfigFile.Identity))" Importance="High" Text="Restoring construction kit model libraries %(ConstructionKitConfigFile.Identity)"/>
        <CkRestore ConstructionKitModelConfigFiles="@(ConstructionKitConfigFile)"
                   IsLocalCatalogEnabled="$(OctoLocalCatalogIsEnabled)"
                   IsPublicGitHubCatalogEnabled="$(OctoPublicGitHubCatalogIsEnabled)"
                   IsPrivateGitHubCatalogEnabled="$(OctoPrivateGitHubCatalogIsEnabled)"
                   OutputPath="$(OctoCkCompileOutputImportFolder)"
                   CacheFilePath="$(OctoCkCompileCacheImportFolder)">
            <Output TaskParameter="CompiledModelFiles" ItemName="CompiledModelFiles" />
            <Output TaskParameter="CacheFiles" ItemName="CacheFiles" />
        </CkRestore>

        <!-- Add AdditionalFiles immediately after restore -->
        <ItemGroup>
            <AdditionalFiles Include="$(OctoCkCompileCacheImportFolder)/*.json" />
        </ItemGroup>

        <!-- Add EmbeddedResource files immediately after restore -->
        <ItemGroup>
            <_OctoImportResourceFilesNew Include="$(OctoCkCompileOutputImportFolder)/*.yaml" Exclude="@(_OctoImportResourceFiles)" />
            <EmbeddedResource Include="@(_OctoImportResourceFilesNew)">
                <LogicalName>$(RootNamespace).%(Filename)%(Extension)</LogicalName>
                <Visible>False</Visible>
                <GenerateCkModelServiceClass>$(OctoGenerateCkModelServiceClass)</GenerateCkModelServiceClass>
            </EmbeddedResource>
            <_OctoImportResourceFiles Include="@(_OctoImportResourceFilesNew)" />
        </ItemGroup>
    </Target>

    <!--
        Note: EmbeddedResource and AdditionalFiles are now added directly in CkCompile and CkRestore targets
        immediately after the files are created. This ensures:
        1. Files exist before being added to the build
        2. AdditionalFiles are available for SourceGenerators during CoreCompile
        3. Items are added before Source Generators are initialized
        4. Incremental builds work correctly
    -->

    <!--
        Remove generated CK compile/restore output and cache folders on Clean.
        Without this the compiled YAMLs (octo-ck-libraries/.../out/*.yaml) and the
        intermediate cache (octo-ck-cache) survive `dotnet clean`. After an engine
        or schema update those stale outputs trigger schema validation errors in
        the source generator on the next build.
    -->
    <Target Name="CkClean" BeforeTargets="Clean">
        <ItemGroup>
            <_OctoCkCompileGeneratedFiles Include="$(OctoCkCompileOutputCompilerFolder)/**/*" />
            <_OctoCkCompileGeneratedFiles Include="$(OctoCkCompileOutputImportFolder)/**/*" />
            <_OctoCkCompileGeneratedFiles Include="$(OctoCkCompileCacheCompileFolder)/**/*" />
            <_OctoCkCompileGeneratedFiles Include="$(OctoCkCompileCacheImportFolder)/**/*" />
        </ItemGroup>
        <Delete Files="@(_OctoCkCompileGeneratedFiles)" />
        <RemoveDir Directories="$(OctoCkCompileOutputCompilerFolder);$(OctoCkCompileOutputImportFolder);$(OctoCkCompileCacheCompileFolder);$(OctoCkCompileCacheImportFolder)" />
    </Target>

    <!--
        CK Model Migration Files Embedding
        This target embeds migration YAML files from ConstructionKit/migrations/ folder
        as embedded resources, making them available via EmbeddedCkMigrationContentProvider.

        Migration files are embedded with the logical name pattern:
        $(RootNamespace).migrations.%(Filename)%(Extension)

        Example: MyApp.CkModel.migrations.migration-meta.yaml
                 MyApp.CkModel.migrations.1-0-0-to-2-0-0.yaml
    -->
    <PropertyGroup>
        <OctoEmbedCkMigrations Condition="'$(OctoEmbedCkMigrations)' == ''">true</OctoEmbedCkMigrations>
    </PropertyGroup>

    <Target Name="CkEmbedMigrations"
            AfterTargets="CkCompile"
            BeforeTargets="CoreCompile"
            Condition="'@(ConstructionKitFolder)' != '' AND '$(OctoEmbedCkMigrations)' == 'true'">

        <!-- Find migration files in each ConstructionKit folder -->
        <ItemGroup>
            <_CkMigrationFilesFromFolder Include="%(ConstructionKitFolder.Identity)/migrations/*.yaml" />
        </ItemGroup>

        <Message Condition="'@(_CkMigrationFilesFromFolder)' != ''"
                 Importance="Normal"
                 Text="Embedding CK model migration files as resources" />

        <!-- Add migration files as EmbeddedResource -->
        <ItemGroup>
            <_OctoMigrationResourceFilesNew Include="@(_CkMigrationFilesFromFolder)" Exclude="@(_OctoMigrationResourceFiles)" />
            <EmbeddedResource Include="@(_OctoMigrationResourceFilesNew)">
                <LogicalName>$(RootNamespace).migrations.%(Filename)%(Extension)</LogicalName>
                <Visible>False</Visible>
            </EmbeddedResource>
            <_OctoMigrationResourceFiles Include="@(_OctoMigrationResourceFilesNew)" />
        </ItemGroup>

        <Message Condition="'@(_OctoMigrationResourceFilesNew)' != ''"
                 Importance="Normal"
                 Text="Embedded migration files: @(_OctoMigrationResourceFilesNew->'%(Filename)%(Extension)', ', ')" />
    </Target>

    <!--
        BlueprintEmbed: discovers blueprint folders declared via <BlueprintFolder> items, validates
        each blueprint.yaml, embeds every blueprint file as a manifest resource with a deterministic
        LogicalName, and emits a blueprints-cache.json the BlueprintSourceGenerator consumes to
        produce IBlueprintEmbeddedSource + AddBlueprint<Name>V<Major> DI extensions.

        Expected folder layout per <BlueprintFolder> item:
            <FolderName>/
              <BlueprintName>-<Version>/
                blueprint.yaml
                seed-data/entities.yaml      (optional)
                migrations/from-X.Y.Z.yaml   (optional)

        Resource namespace convention:
            $(RootNamespace).<FolderName>.<BlueprintName>-<Version>
        with sibling files appended as '.' separated path segments.
    -->
    <PropertyGroup>
        <OctoBlueprintsCacheFile Condition="'$(OctoBlueprintsCacheFile)' == ''">$(IntermediateOutputPath)octo-blueprints/blueprints-cache.json</OctoBlueprintsCacheFile>
    </PropertyGroup>

    <Target Name="BlueprintEmbed"
            AfterTargets="ResolveProjectReferences"
            BeforeTargets="CoreCompile;CoreGenerateMSBuildEditorConfigFileShouldRun"
            Inputs="@(BlueprintFolder->'%(Identity)/**/*.yaml')"
            Outputs="$(OctoBlueprintsCacheFile)"
            Condition="'@(BlueprintFolder)' != ''">

        <Message Importance="High" Text="Embedding blueprints (target framework $(TargetFramework))" />

        <BlueprintEmbed BlueprintFolders="@(BlueprintFolder)"
                        RootNamespace="$(RootNamespace)"
                        CacheFilePath="$(OctoBlueprintsCacheFile)">
            <Output TaskParameter="EmbeddedResourceItems" ItemName="_OctoBlueprintEmbeddedResourceItems" />
        </BlueprintEmbed>

        <ItemGroup>
            <EmbeddedResource Include="@(_OctoBlueprintEmbeddedResourceItems)" />
            <!-- AdditionalFiles lets the source generator pick up the cache without needing to know
                 the IntermediateOutputPath. -->
            <AdditionalFiles Include="$(OctoBlueprintsCacheFile)" />
        </ItemGroup>
    </Target>

</Project>