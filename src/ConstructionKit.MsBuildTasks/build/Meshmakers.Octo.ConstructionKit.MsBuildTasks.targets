<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
    
    <!--Defining all the text files input parameters-->
    <ItemGroup>
        <ConstructionKitFolder Condition="Exists(ConstructionKit)" Include="ConstructionKit"/>
    </ItemGroup>

    <Target Name="GatherConstructionKitFiles">
        <ItemGroup>
            <ConstructionKitFolderInputFiles Include="@(ConstructionKitFolder->'%(Identity)/**/*.yaml')" Exclude="@(ConstructionKitFolder->'%(Identity)/**/ckModel.yaml')" />
            <ConstructionKitFolderOutFiles Include="@(ConstructionKitFolder->'%(Identity)/*.yaml');@(ConstructionKitFolder->'%(Identity)/*.json')" Exclude="@(ConstructionKitFolder->'%(Identity)/ckModel.yaml')" />
        </ItemGroup>
    </Target>
    
    <!--It is generated a target which is executed before the compilation-->
    <Target Name="CkBeforeCompile" BeforeTargets="BeforeCompile" Inputs="@(ConstructionKitFolderInputFiles)" Outputs="@(ConstructionKitFolderOutFiles)"
            DependsOnTargets="GatherConstructionKitFiles">

        <Message Importance="High" Text="Building construction kit (target framework $(TargetFramework))" />
        <!--Calling our custom task-->
        <CkCompile ConstructionKitFolders="@(ConstructionKitFolder)" CreateCacheFile="$(OctoCreateCacheFile)">
            <Output TaskParameter="CompiledModelFiles" PropertyName="CompiledModelFiles" />
            <Output TaskParameter="CacheFiles" PropertyName="CacheFiles" />
        </CkCompile>
        
        <ItemGroup>
            <None Remove="$(CompiledModelFiles)" />
            <EmbeddedResource Include="$(CompiledModelFiles)">
                <GenerateCkModelServiceClass>$(OctoGenerateCkModelServiceClass)</GenerateCkModelServiceClass>
            </EmbeddedResource>
        </ItemGroup>

        <ItemGroup>
            <None Remove="$(CacheFiles)" />
            <AdditionalFiles Include="$(CacheFiles)" />
        </ItemGroup>
        
        <Copy Condition="$(OctoCopyCkModelToOuputDirectory)" SourceFiles="$(CompiledModelFiles)" DestinationFolder="$(OutputPath)" SkipUnchangedFiles="true" />
        <Copy Condition="$(OctoCopyCkModelToOuputDirectory)" SourceFiles="$(CacheFiles)" DestinationFolder="$(OutputPath)" SkipUnchangedFiles="true" />
    </Target>

    <!--The generated file is deleted after a general clean. It will force the regeneration on rebuild-->
    <Target Name="AfterClean">
        <Delete Files="@(ConstructionKitFolderOutFiles)" />
    </Target>
    
</Project>