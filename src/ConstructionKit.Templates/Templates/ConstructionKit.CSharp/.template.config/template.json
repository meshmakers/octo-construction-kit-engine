{
  "$schema": "http://json.schemastore.org/template",
  "author": "Meshmakers GmbH and Contributors",
  "classifications": [
    "Octo Mesh",
    "Construction Kit"
  ],
  "identity": "Meshmakers.Octo.ConstructionKit.Templates.CSharp",
  "groupIdentity": "Meshmakers.Octo",
  "name": "Octo Mesh Construction Kit Library",
  "description": "Create Octo Mesh Construction Kit Library",
  "shortName": "ConstructionKit",
  "tags": {
    "language": "C#",
    "type": "project"
  },
  "sourceName": "GeneratedConstructionKitProject",
  "defaultName": "ConstructionKit",
  "preferNameDirectory": true,
  "symbols": {
    "compilerVersion": {
      "type": "parameter",
      "datatype": "string",
      "replaces": "CompilerVersion",
      "defaultValue": "0.0.2308.25003",
      "description": "Version of OctoMesh Construction Kit Compiler to install."
    }
  },
  "postActions": [
    {
      "actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
      "description": "Installs the Octo Mesh Construction Kit Compiler dotnet tool",
      "continueOnError": false,
      "manualInstructions": [
        {
          "text": "Add the 'Meshmakers.Octo.ConstructionKit.Compiler' package to your project via nuget"
        }
      ],
      "args": {
        "executable": "dotnet",
        "args": "tool install -g 'Meshmakers.Octo.ConstructionKit.Compiler' --version (compilerVersion)",
        "redirectStandardOutput": false,
        "redirectStandardError": false
      }
    }
  ]
}
