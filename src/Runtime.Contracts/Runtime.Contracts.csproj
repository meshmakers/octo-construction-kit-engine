<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <Description>Contracts of Octo Mesh for Runtime functionality</Description>
        <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
        <PackageId>Meshmakers.Octo.Runtime.Contracts</PackageId>
        <AssemblyName>Meshmakers.Octo.Runtime.Contracts</AssemblyName>
        <RootNamespace>Meshmakers.Octo.Runtime.Contracts</RootNamespace>
        <TargetFrameworks>net8.0;netstandard2.0</TargetFrameworks>
    </PropertyGroup>

    <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|AnyCPU'">
        <OutputPath>..\..\bin\Debug\</OutputPath>
        <DocumentationFile>..\..\bin\Debug\Meshmakers.Octo.Runtime.Contracts.xml</DocumentationFile>
        <NoWarn>1701;1702;CS8002</NoWarn>
    </PropertyGroup>

    <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|AnyCPU'">
        <OutputPath>..\..\bin\Release\</OutputPath>
        <DocumentationFile>..\..\bin\Release\Meshmakers.Octo.Runtime.Contracts.xml</DocumentationFile>
        <NoWarn>1701;1702;CS8002</NoWarn>
    </PropertyGroup>

    <ItemGroup>
        <None Include="..\..\assets\meshmakers64.png">
            <Pack>True</Pack>
            <PackagePath />
            <Link>meshmakers64.png</Link>
        </None>
        <None Include="..\..\LICENSE">
            <Pack>True</Pack>
            <PackagePath />
            <Link>LICENSE</Link>
        </None>
    </ItemGroup>

    <ItemGroup>
      <EmbeddedResource Include="Serialization\Schema\runtime-element-association.json">
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      </EmbeddedResource>
      <EmbeddedResource Include="Serialization\Schema\runtime-element-attribute.json">
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      </EmbeddedResource>
      <EmbeddedResource Include="Serialization\Schema\runtime-element-entity.json">
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      </EmbeddedResource>
      <EmbeddedResource Include="Serialization\Schema\runtime-model.json">
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      </EmbeddedResource>
    </ItemGroup>


    <ItemGroup>
      <ProjectReference Include="..\ConstructionKit.Contracts\ConstructionKit.Contracts.csproj" />
    </ItemGroup>


    <ItemGroup>
      <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
    </ItemGroup>





</Project>
