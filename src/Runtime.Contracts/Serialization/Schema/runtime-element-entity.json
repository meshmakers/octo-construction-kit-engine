{
  "$id": "https://schemas.meshmakers.cloud/runtime-elements-entity.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "RtEntity": {
      "type": "object",
      "title": "RtEntity",
      "description": "A runtime entity",
      "properties": {
        "rtId": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{24}$"
        },
        "rtCreationDateTime": {
          "type": "string",
          "format": "date-time"
        },
        "rtChangedDateTime": {
          "type": "string",
          "format": "date-time"
        },
        "ckTypeId": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9-_.]+/[a-zA-Z0-9-_.]+$"
        },
        "rtWellKnownName": {
          "type": "string"
        },
        "rtState": {
          "type": "string",
          "enum": [
            "Active",
            "Archived"
          ]
        },
        "attributes": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "https://schemas.meshmakers.cloud/runtime-elements-attribute.schema.json#/definitions/RtAttribute"
          }
        },
        "associations": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "https://schemas.meshmakers.cloud/runtime-elements-association.schema.json#/definitions/RtAssociation"
          }
        }
      },
      "additionalProperties": false,
      "additionalItems": false,
      "required": [
        "rtId",
        "ckTypeId"
      ]
    }
  }
}
