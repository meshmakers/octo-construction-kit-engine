<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <Description>OctoMesh System contruction kit model</Description>
        <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
        <PackageId>Meshmakers.Octo.ConstructionKit.Models.System</PackageId>
        <AssemblyName>Meshmakers.Octo.ConstructionKit.Models.System</AssemblyName>
        <RootNamespace>Meshmakers.Octo.ConstructionKit.Models.System</RootNamespace>
        <OctoSkipCkCompile Condition="'$(Configuration)'=='Release'">true</OctoSkipCkCompile>
        <Configurations>Debug;Release;DebugL</Configurations>
        <Platforms>AnyCPU</Platforms>
        <TargetFrameworks>net8.0;netstandard2.0</TargetFrameworks>
        <OutputPath>..\..\bin\$(Configuration)\</OutputPath>
    </PropertyGroup>

    <ItemGroup>
        <None Remove="ConstructionKit\ck-*.yaml" />
        <EmbeddedResource Include="ConstructionKit\ck-*.yaml">
            <GenerateCkModelServiceClass>true</GenerateCkModelServiceClass>
        </EmbeddedResource>
        <None Remove="ConstructionKit\ck-*.cache.json" />
        <AdditionalFiles Include="ConstructionKit\ck-*.cache.json" />
    </ItemGroup>

    <ItemGroup>
        <None Include="..\..\assets\meshmakers64.png">
            <Pack>True</Pack>
            <PackagePath />
            <Link>meshmakers64.png</Link>
        </None>
        <None Include="..\..\LICENSE">
            <Pack>True</Pack>
            <PackagePath />
            <Link>LICENSE</Link>
        </None>
    </ItemGroup>

    <!-- Import the ConstructionKit.SourceGeneration props and targets only because the package is not used as nuget package -->
    <Import Project="../ConstructionKit.SourceGeneration/build/Meshmakers.Octo.ConstructionKit.SourceGeneration.props"  />
    <Import Project="../ConstructionKit.SourceGeneration/build/Meshmakers.Octo.ConstructionKit.SourceGeneration.targets"  />

    <ItemGroup>
        <ProjectReference Include="..\ConstructionKit.SourceGeneration\ConstructionKit.SourceGeneration.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
        <ProjectReference Include="..\Runtime.Contracts\Runtime.Contracts.csproj" />
    </ItemGroup>

</Project>
