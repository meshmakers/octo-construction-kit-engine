<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <TargetFramework>net8.0</TargetFramework>
        <AssemblyName>TestCkModel</AssemblyName>
        <RootNamespace>TestCkModel</RootNamespace>
        <Configurations>Debug;Release;DebugL</Configurations>
        <Platforms>AnyCPU</Platforms>
        <OctoPublishCkModel Condition="'$(TargetFramework)' == 'net8.0'">true</OctoPublishCkModel>
    </PropertyGroup>

    <!-- Import the ConstructionKit props and targets only because the package is not used as nuget package -->
    <Import Project="../../src/ConstructionKit.SourceGeneration/build/Meshmakers.Octo.ConstructionKit.SourceGeneration.props"/>

    <ItemGroup>
        <ProjectReference Include="..\..\src\ConstructionKit.SourceGeneration\ConstructionKit.SourceGeneration.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false"/>
        <ProjectReference Include="..\..\src\Runtime.Engine\Runtime.Engine.csproj"/>
    </ItemGroup>

    <ItemGroup>
        <ConstructionKitFolder Visible="false" Include="ConstructionKit"/>
        <ConstructionKitFolder Visible="false" Include="CkTest\ConstructionKit" />
    </ItemGroup>

    <ItemGroup>
      <None Remove="binRelease\net8.0\octo-ck-librariesTestCkModelout\ck-system.testidentity.yaml" />
    </ItemGroup>

    <ItemGroup>
      <Folder Include="binRelease\net8.0\octo-ck-librariesTestCkModelout\" />
    </ItemGroup>
</Project>
